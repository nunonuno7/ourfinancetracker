DEBUG=True
SECRET_KEY=dev-only-change-me

# Leave DATABASE_URL and SUPABASE_DB_URL empty to use local SQLite.
DATABASE_URL=
SUPABASE_DB_URL=

# Optional local email settings. If EMAIL_HOST is empty and DEBUG=True,
# Django falls back to the console email backend.
DEFAULT_FROM_EMAIL=noreply@example.com
SERVER_EMAIL=noreply@example.com
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_PORT=587
EMAIL_TIMEOUT=20
EMAIL_USE_SSL=false
EMAIL_USE_TLS=true
EMAIL_LINK_DOMAIN=127.0.0.1:8000

SHOW_DEBUG_TOOLBAR=0
TIME_ZONE=Europe/Lisbon

# Optional integrations
SENTRY_DSN=
REDIS_URL=

# Optional extra hosts/origins for local or preview environments
EXTRA_ALLOWED_HOSTS=
EXTRA_CSRF_TRUSTED_ORIGINS=
